---
interface Props {
  items: Array<{ href: string; label: string }>;
  empty?: string;
}

const { items, empty = "Nenhuma." } = Astro.props;
---

{
  items.length === 0 ? (
    <p><em>{empty}</em></p>
  ) : (
    <ul class="relation-list">
      {items.map(({ href, label }) => (
        <li><a href={href}>{label}</a></li>
      ))}
    </ul>
  )
}
