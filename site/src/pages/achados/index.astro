---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntityCard from "../../components/EntityCard.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import RelationList from "../../components/RelationList.astro";
import { achadoStatusBadge } from "../../lib/status";
import { getAchadoState } from "../../lib/site-data";
import { href } from "../../consts";

const achados = (await getCollection("achados")).sort((a, b) => a.data.id.localeCompare(b.data.id));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Achados" description="Listagem de todos os achados de auditoria do catálogo Sisprev.">
  <h1>Achados</h1>
  <p>{achados.length} achado(s).</p>

  {
    achados.map((achado) => {
      // Selo e regras_afetadas vêm do estado emitido (dados-do-site.json),
      // nunca do frontmatter cru — a única fonte de verdade para estado
      // efetivo de auditoria (RFC 0003 §4).
      const state = getAchadoState(achado.data.id);
      const badge = achadoStatusBadge(state);
      return (
        <EntityCard href={href(`achados/${achado.data.id}/`, base)} title={achado.data.nome}>
          <Fragment slot="badges">
            <StatusBadge tone={badge.tone} label={badge.label} />
          </Fragment>
          <p>{achado.data.natureza} · verificação {achado.data.verificacao}</p>
          <RelationList
            items={state.regras_afetadas.map((regraId) => ({
              href: href(`regras/${regraId}/`, base),
              label: regraId,
            }))}
          />
        </EntityCard>
      );
    })
  }
</BaseLayout>
