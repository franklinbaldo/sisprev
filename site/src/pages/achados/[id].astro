---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MetadataGrid from "../../components/MetadataGrid.astro";
import RelationList from "../../components/RelationList.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import { achadoStatusBadge } from "../../lib/status";
import { getAchadoState } from "../../lib/site-data";
import { href } from "../../consts";

export async function getStaticPaths() {
  const achados = await getCollection("achados");
  return achados.map((entry) => ({ params: { id: entry.data.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL;

// Selo, situação/severidade e regras_afetadas vêm do estado emitido
// (dados-do-site.json), nunca do frontmatter cru (RFC 0003 §4).
const state = getAchadoState(entry.data.id);
const badge = achadoStatusBadge(state);

const regraEntries = await Promise.all(state.regras_afetadas.map((id) => getEntry("regras", id)));
---

<BaseLayout title={entry.data.nome} description={`Achado ${entry.data.id} do catálogo Sisprev.`}>
  <p><a href={href("achados/", base)}>&larr; Achados</a></p>
  <h1>{entry.data.nome}</h1>
  <p>
    <StatusBadge tone={badge.tone} label={badge.label} />
    {" "}
    <span class="status-badge" data-tone="neutro">{entry.data.id}</span>
  </p>

  <MetadataGrid
    items={[
      { label: "Situação", value: state.situacao },
      { label: "Severidade", value: state.severidade },
      { label: "Natureza", value: entry.data.natureza },
      { label: "Verificação", value: entry.data.verificacao },
      { label: "Detectado em", value: entry.data.detectado_em.toISOString().slice(0, 10) },
      { label: "Detectado por", value: entry.data.detectado_por },
    ]}
  />

  <h2>Regras afetadas</h2>
  <RelationList
    items={regraEntries
      .filter((r): r is NonNullable<typeof r> => r !== undefined)
      .map((r) => ({ href: href(`regras/${r.data.id}/`, base), label: r.data.nome }))}
  />

  {
    entry.data.deteccoes.length > 0 && (
      <>
        <h2>Detecções (mecânicas)</h2>
        <ul>
          {entry.data.deteccoes.map((d) => (
            <li>
              <code>{d.detector}</code> — <code>{d.fingerprint}</code>
            </li>
          ))}
        </ul>
      </>
    )
  }

  <h2>Análise</h2>
  <div class="document-body">
    <Content />
  </div>
</BaseLayout>
